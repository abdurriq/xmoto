## Web / Emscripten build

# libxml2 is downloaded at setup time by dev-scripts/env-web.sh
# (run: curl -sL https://download.gnome.org/sources/libxml2/2.9/libxml2-2.9.14.tar.xz | tar -xJ -C vendor/libxml2 --strip-components=1)
vendor/libxml2/

# xmoto.bin is generated by the native build (xmoto --pack xmoto.bin bin/)
# and used by the web build via --preload-file.  Do not commit it (51 MB).
bin/xmoto.bin

# Emscripten build artefacts
build-web/

# Native build artefacts
build-native/
